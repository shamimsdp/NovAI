            "button": {
                "color": {
                    "background": "#1E1E2E",
                    "text": "#FFFFFF"
                },
                ":hover": {
                    "color": { "background": "#4F3CC9" }
                }
            }
        },
        "blocks": {
            "core/navigation": {
                "color": { "text": "#374151" }
            }
        }
    }
