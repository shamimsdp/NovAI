{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "color": {
            "custom": false,
            "customGradient": false,
            "defaultPalette": false,
            "defaultGradients": false,
            "palette": [
                {
                    "slug": "nova-purple",
                    "color": "#6C47FF",
                    "name": "Nova Purple"
                },
                {
                    "slug": "stellar-violet",
                    "color": "#A78BFA",
                    "name": "Stellar Violet"
                },
                {
                    "slug": "orbit-blue",
                    "color": "#38BDF8",
                    "name": "Orbit Blue"
                },
                {
                    "slug": "deep-space",
                    "color": "#0D0B1A",
                    "name": "Deep Space"
                },
                {
                    "slug": "nebula",
                    "color": "#1E1A38",
                    "name": "Nebula"
                },
                {
                    "slug": "cloud-white",
                    "color": "#F7F6FE",
                    "name": "Cloud White"
                },
                {
                    "slug": "surface-dark",
                    "color": "#2A2550",
                    "name": "Surface Dark"
                },
                {
                    "slug": "text-muted",
                    "color": "#8B83C4",
                    "name": "Text Muted"
                },
                {
                    "slug": "text-secondary",
                    "color": "#C5BEE8",
                    "name": "Text Secondary"
                },
                {
                    "slug": "white",
                    "color": "#FFFFFF",
                    "name": "White"
                },
                {
                    "slug": "forge-amber",
                    "color": "#EAB308",
                    "name": "Forge Amber"
                },
                {
                    "slug": "forge-dark",
                    "color": "#0F0F0F",
                    "name": "Forge Dark"
                },
                {
                    "slug": "orbit-dark",
                    "color": "#03111F",
                    "name": "Orbit Dark"
                },
                {
                    "slug": "success",
                    "color": "#34D399",
                    "name": "Success"
                },
                {
                    "slug": "warning",
                    "color": "#FCD34D",
                    "name": "Warning"
                },
                {
                    "slug": "border-subtle",
                    "color": "#2E2857",
                    "name": "Border Subtle"
                }
            ],
            "gradients": [
                {
                    "slug": "nova-gradient",
                    "name": "Nova Gradient",
                    "gradient": "linear-gradient(135deg, #6C47FF 0%, #A78BFA 50%, #38BDF8 100%)"
                },
                {
                    "slug": "nova-gradient-vertical",
                    "name": "Nova Gradient Vertical",
                    "gradient": "linear-gradient(180deg, #6C47FF 0%, #A78BFA 100%)"
                },
                {
                    "slug": "space-fade",
                    "name": "Space Fade",
                    "gradient": "linear-gradient(180deg, #0D0B1A 0%, #1E1A38 100%)"
                },
                {
                    "slug": "orbit-gradient",
                    "name": "Orbit Gradient",
                    "gradient": "linear-gradient(135deg, #0EA5E9 0%, #38BDF8 50%, #6C47FF 100%)"
                },
                {
                    "slug": "forge-gradient",
                    "name": "Forge Gradient",
                    "gradient": "linear-gradient(135deg, #EAB308 0%, #FDE68A 100%)"
                }
            ]
        },
        "typography": {
            "customFontSize": true,
            "defaultFontSizes": false,
            "fontFamilies": [
                {
                    "slug": "inter",
                    "name": "Inter",
                    "fontFamily": "'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif",
                    "fontFace": [
                        {
                            "src": ["file:./assets/fonts/inter-400.woff2"],
                            "fontWeight": "400",
                            "fontStyle": "normal",
                            "fontDisplay": "swap"
                        },
                        {
                            "src": ["file:./assets/fonts/inter-500.woff2"],
                            "fontWeight": "500",
                            "fontStyle": "normal",
                            "fontDisplay": "swap"
                        },
                        {
                            "src": ["file:./assets/fonts/inter-600.woff2"],
                            "fontWeight": "600",
                            "fontStyle": "normal",
                            "fontDisplay": "swap"
                        }
                    ]
                },
                {
                    "slug": "system-mono",
                    "name": "System Mono",
                    "fontFamily": "ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, monospace"
                }
            ],
            "fontSizes": [
                { "slug": "xs", "size": "12px", "name": "XS" },
                { "slug": "sm", "size": "14px", "name": "SM" },
                { "slug": "md", "size": "16px", "name": "MD" },
                { "slug": "lg", "size": "18px", "name": "LG" },
                {
                    "slug": "xl",
                    "size": "clamp(20px, 2.5vw, 24px)",
                    "name": "XL"
                },
                {
                    "slug": "2xl",
                    "size": "clamp(24px, 3vw, 32px)",
                    "name": "2XL"
                },
                {
                    "slug": "3xl",
                    "size": "clamp(32px, 4vw, 42px)",
                    "name": "3XL"
                },
                {
                    "slug": "4xl",
                    "size": "clamp(40px, 5vw, 56px)",
                    "name": "4XL"
                },
                {
                    "slug": "5xl",
                    "size": "clamp(52px, 7vw, 72px)",
                    "name": "5XL"
                }
            ]
        },
        "spacing": {
            "spacingSizes": [
                { "slug": "xs", "size": "8px", "name": "XS" },
                { "slug": "sm", "size": "16px", "name": "SM" },
                { "slug": "md", "size": "24px", "name": "MD" },
                { "slug": "lg", "size": "32px", "name": "LG" },
                { "slug": "xl", "size": "48px", "name": "XL" },
                { "slug": "2xl", "size": "64px", "name": "2XL" },
                { "slug": "3xl", "size": "96px", "name": "3XL" }
            ],
            "units": ["px", "rem", "em", "%", "vw", "vh"],
            "defaultSpacingSizes": false
        },
        "layout": {
            "contentSize": "780px",
            "wideSize": "1200px"
        },
        "border": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true
        },
        "shadow": {
            "defaultPresets": false,
            "presets": [
                {
                    "slug": "card",
                    "name": "Card",
                    "shadow": "0 1px 3px rgba(0,0,0,0.3), 0 1px 2px rgba(0,0,0,0.2)"
                },
                {
                    "slug": "card-hover",
                    "name": "Card Hover",
                    "shadow": "0 10px 30px rgba(108,71,255,0.2), 0 1px 3px rgba(0,0,0,0.3)"
                },
                {
                    "slug": "glow-purple",
                    "name": "Glow Purple",
                    "shadow": "0 0 40px rgba(108,71,255,0.35)"
                },
                {
                    "slug": "glow-blue",
                    "name": "Glow Blue",
                    "shadow": "0 0 40px rgba(56,189,248,0.25)"
                }
            ]
        },
        "dimensions": {
            "minHeight": true
        },
        "position": {
            "sticky": true
        },
        "blocks": {
            "core/button": {
                "border": { "radius": true }
            },
            "core/navigation": {
                "typography": { "fontSize": true }
            },
            "core/post-featured-image": {
                "dimensions": { "aspectRatio": true }
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--deep-space)",
            "text": "var(--wp--preset--color--cloud-white)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--inter)",
            "fontSize": "var(--wp--preset--font-size--md)",
            "lineHeight": "1.7",
            "fontWeight": "400"
        },
        "spacing": {
            "blockGap": "var(--wp--preset--spacing--md)",
            "padding": {
                "top": "0px",
                "right": "var(--wp--preset--spacing--sm)",
                "bottom": "0px",
                "left": "var(--wp--preset--spacing--sm)"
            }
        },
        "elements": {
            "h1": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--4xl)",
                    "fontWeight": "600",
                    "lineHeight": "1.1",
                    "letterSpacing": "-0.03em"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--3xl)",
                    "fontWeight": "600",
                    "lineHeight": "1.15",
                    "letterSpacing": "-0.02em"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--2xl)",
                    "fontWeight": "600",
                    "lineHeight": "1.25",
                    "letterSpacing": "-0.015em"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--xl)",
                    "fontWeight": "600",
                    "lineHeight": "1.3"
                }
            },
            "h5": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--lg)",
                    "fontWeight": "500",
                    "lineHeight": "1.4"
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--md)",
                    "fontWeight": "500",
                    "lineHeight": "1.5"
                }
            },
            "link": {
                "color": { "text": "var(--wp--preset--color--stellar-violet)" },
                ":hover": {
                    "color": { "text": "var(--wp--preset--color--nova-purple)" }
                }
            },
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--nova-purple)",
                    "text": "var(--wp--preset--color--white)"
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--sm)",
                    "fontWeight": "500"
                },
                "border": { "radius": "10px" },
                "spacing": {
                    "padding": {
                        "top": "10px",
                        "right": "22px",
                        "bottom": "10px",
                        "left": "22px"
                    }
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--stellar-violet)"
                    }
                }
            }
        },
        "blocks": {
            "core/separator": {
                "color": { "text": "var(--wp--preset--color--border-subtle)" },
                "border": { "color": "var(--wp--preset--color--border-subtle)" }
            },
            "core/code": {
                "color": {
                    "background": "var(--wp--preset--color--forge-dark)",
                    "text": "#A78BFA"
                },
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--system-mono)",
                    "fontSize": "var(--wp--preset--font-size--sm)"
                },
                "border": { "radius": "8px" },
                "spacing": {
                    "padding": {
                        "top": "16px",
                        "right": "20px",
                        "bottom": "16px",
                        "left": "20px"
                    }
                }
            },
            "core/pullquote": {
                "border": {
                    "color": "var(--wp--preset--color--nova-purple)",
                    "width": "2px"
                }
            }
        },
        "css": ":root { --novai-transition: 200ms cubic-bezier(0.4,0,0.2,1); --novai-border-sm: 6px; --novai-border-md: 10px; --novai-border-lg: 16px; --novai-border-xl: 24px; }"
    },
    "customTemplates": [
        {
            "name": "blank",
            "title": "Blank",
            "postTypes": ["page", "post"]
        },
        {
            "name": "page-no-header",
            "title": "Page — No Header",
            "postTypes": ["page"]
        },
        {
            "name": "single-sidebar",
            "title": "Single Post — With Sidebar",
            "postTypes": ["post"]
        }
    ],
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        },
        {
            "name": "sidebar",
            "title": "Sidebar",
            "area": "uncategorized"
        }
    ],
    "patterns": []
}
